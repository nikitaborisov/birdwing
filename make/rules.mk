# ================================================================
# Default target
# ================================================================

all: gpu-ntt $(TARGET)

# ================================================================
# Directory creation
# ================================================================

$(OBJ_DIR):
	mkdir -p $@

$(TEST_BUILD):
	mkdir -p $@

# ================================================================
# Compilation rules
# ================================================================

# Compile C++
$(OBJ_DIR)/%.o: $(SRC_DIR)/%.cpp | $(OBJ_DIR)
	$(CXX) $(CXXFLAGS) $(INCLUDES) -c $< -o $@

# Compile CUDA
$(OBJ_DIR)/%.o: $(SRC_DIR)/%.cu | $(OBJ_DIR)
	$(NVCC) $(NVCCFLAGS) $(INCLUDES) -c $< -o $@

# Compile main
$(MAIN_OBJ): $(MAIN_SRC) | $(OBJ_DIR)
	$(CXX) $(CXXFLAGS) $(INCLUDES) -c $< -o $@

# ================================================================
# Main executable
# ================================================================

$(TARGET): $(OBJS) | $(GPU_NTT_LIB)
	$(NVCC) $(NVCCFLAGS) $(INCLUDES) $(LIB_PATHS) \
		-o $@ $(OBJS) $(LIBS)

# ================================================================
# Cleanup
# ================================================================

clean:
	rm -rf $(OBJ_DIR) $(TARGET) $(BENCH_TARGET)

# ================================================================
# Phony targets
# ================================================================

.PHONY: all clean